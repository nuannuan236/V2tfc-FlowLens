<ui:FluentWindow x:Class="V2rayN.FlowLens.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="{DynamicResource App.Title}" Height="760" Width="1180" MinHeight="640" MinWidth="960"
                 Background="{StaticResource FlowLensSurfaceBrush}"
                 Foreground="{StaticResource FlowLensTextBrush}"
                 FontFamily="Segoe UI"
                 ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{DynamicResource App.Title}" ShowMaximize="True" ShowMinimize="True" ShowClose="True">
            <ui:TitleBar.TrailingContent>
                <TextBlock Text="{DynamicResource App.Version}" Margin="0,0,14,0" VerticalAlignment="Center" Foreground="{StaticResource FlowLensMutedBrush}" />
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="14,8,14,14">
            <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:Card Grid.Row="0" Padding="14" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.1*" MinWidth="260" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                    <TextBlock Text="{DynamicResource Label.LogPath}" Style="{StaticResource FlowLensLabelStyle}" />
                    <TextBox x:Name="LogPathTextBox" Style="{StaticResource FlowLensInputStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,10">
                    <TextBlock Text="{DynamicResource Label.ProxyPorts}" Style="{StaticResource FlowLensLabelStyle}" />
                    <TextBox x:Name="ProxyPortsTextBox" Text="10808,10809" Style="{StaticResource FlowLensInputStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,10,10">
                    <TextBlock Text="{DynamicResource Label.Refresh}" Style="{StaticResource FlowLensLabelStyle}" />
                    <ui:NumberBox x:Name="RefreshSecondsNumberBox" Value="2" Minimum="1" Maximum="3600" SmallChange="1" MaxDecimalPlaces="0" MinHeight="32" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,10,10">
                    <TextBlock Text="{DynamicResource Label.Mode}" Style="{StaticResource FlowLensLabelStyle}" />
                    <ComboBox x:Name="AttributionModeComboBox" Style="{StaticResource FlowLensInputStyle}" SelectedIndex="0">
                        <ComboBoxItem Content="NormalProxy" />
                        <ComboBoxItem Content="Tun" />
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,10">
                    <Button x:Name="RefreshButton" Content="{DynamicResource Action.Refresh}" Style="{StaticResource FlowLensPrimaryButtonStyle}" Margin="0,0,8,0" Click="RefreshButton_Click" />
                    <Button x:Name="PauseButton" Content="{DynamicResource Action.Pause}" Style="{StaticResource FlowLensSecondaryButtonStyle}" Margin="0,0,8,0" Click="PauseButton_Click" />
                    <Button x:Name="ResetSessionButton" Content="{DynamicResource Action.ResetSession}" Style="{StaticResource FlowLensSecondaryButtonStyle}" Click="ResetSessionButton_Click" />
                </StackPanel>

                <WrapPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5" Margin="0,0,0,8">
                    <CheckBox x:Name="HideCoreProcessesCheckBox" Content="{DynamicResource Option.HideCores}" IsChecked="True" VerticalAlignment="Center" Margin="0,0,14,0" />
                    <CheckBox x:Name="OnlyProxyCheckBox" Content="{DynamicResource Option.ProxyOnly}" VerticalAlignment="Center" Margin="0,0,18,0" />
                    <TextBlock Text="{DynamicResource Label.Language}" Style="{StaticResource FlowLensLabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox x:Name="UiLanguageComboBox" Width="132" Style="{StaticResource FlowLensInputStyle}" Margin="0,0,18,0" SelectionChanged="UiLanguageComboBox_SelectionChanged" SelectedIndex="0">
                        <ComboBoxItem Content="{DynamicResource Language.English}" Tag="English" />
                        <ComboBoxItem Content="{DynamicResource Language.Chinese}" Tag="简体中文" />
                    </ComboBox>
                    <TextBlock Text="{DynamicResource Label.Filter}" Style="{StaticResource FlowLensLabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox x:Name="FilterTextBox" Width="220" Style="{StaticResource FlowLensInputStyle}" Margin="0,0,10,0" TextChanged="FilterControl_Changed" />
                    <ComboBox x:Name="OutboundFilterComboBox" Width="130" Style="{StaticResource FlowLensInputStyle}" Margin="0,0,10,0" SelectionChanged="FilterControl_Changed" SelectedIndex="0">
                        <ComboBoxItem Content="All" />
                        <ComboBoxItem Content="proxy" />
                        <ComboBoxItem Content="direct" />
                        <ComboBoxItem Content="unknown" />
                    </ComboBox>
                    <Button x:Name="OpenHistoryFolderButton" Content="{DynamicResource Action.OpenHistoryFolder}" Style="{StaticResource FlowLensSecondaryButtonStyle}" Margin="0,0,8,0" Click="OpenHistoryFolderButton_Click" />
                    <Button x:Name="CopyDiagnosticsButton" Content="{DynamicResource Action.CopyDiagnostics}" Style="{StaticResource FlowLensSecondaryButtonStyle}" Margin="0,0,8,0" Click="CopyDiagnosticsButton_Click" />
                    <Button x:Name="CopyTunEvidenceTopButton" Content="{DynamicResource Action.CopyTunEvidence}" Style="{StaticResource FlowLensSecondaryButtonStyle}" Click="CopyTunEvidenceJsonButton_Click" />
                </WrapPanel>

                <WrapPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5">
                    <Border Style="{StaticResource FlowLensChipStyle}" Background="{StaticResource FlowLensChipAccentBrush}">
                        <TextBlock Text="{Binding CurrentDiagnostics.AdminDisplay}" TextTrimming="CharacterEllipsis" />
                    </Border>
                    <Border Style="{StaticResource FlowLensChipStyle}">
                        <TextBlock Text="{Binding CurrentDiagnostics.EtwStatus}" TextTrimming="CharacterEllipsis" MaxWidth="260" />
                    </Border>
                    <Border Style="{StaticResource FlowLensChipStyle}">
                        <TextBlock Text="{Binding CurrentDiagnostics.AttributionModeDisplay}" TextTrimming="CharacterEllipsis" MaxWidth="180" />
                    </Border>
                    <Border Style="{StaticResource FlowLensChipStyle}">
                        <TextBlock Text="{Binding CurrentDiagnostics.LogDiscoveryStatus, StringFormat=Logs: {0}}" TextTrimming="CharacterEllipsis" MaxWidth="160" />
                    </Border>
                    <Border Style="{StaticResource FlowLensChipStyle}">
                        <TextBlock Text="{Binding CurrentDiagnostics.ConfidenceStatsDisplay}" TextTrimming="CharacterEllipsis" MaxWidth="330" />
                    </Border>
                </WrapPanel>
            </Grid>
        </ui:Card>

        <ui:InfoBar Grid.Row="1" x:Name="LogHealthWarningBorder" Severity="Warning" IsClosable="False" IsOpen="False" Title="{DynamicResource Label.LogHealth}" Message="{DynamicResource Warning.LogHealth}" Margin="0,0,0,12" />

        <ui:InfoBar Grid.Row="2" x:Name="EtwWarningBorder" Severity="Informational" IsClosable="False" IsOpen="False" Title="{DynamicResource Label.Etw}" Margin="0,0,0,12" />

        <TabControl Grid.Row="3" Background="{StaticResource FlowLensPanelBrush}" BorderBrush="{StaticResource FlowLensBorderBrush}">
            <TabItem Header="{DynamicResource Tab.Applications}">
                <DataGrid ItemsSource="{Binding ApplicationSummaries}" Style="{StaticResource FlowLensDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource Column.Application}" Binding="{Binding Application}" Width="2*" />
                        <DataGridTextColumn Header="{DynamicResource Column.Pid}" Binding="{Binding ProcessId}" Width="90" />
                        <DataGridTextColumn Header="{DynamicResource Column.TotalTraffic}" Binding="{Binding TotalTraffic}" Width="120" />
                        <DataGridTextColumn Header="{DynamicResource Column.ProxyTraffic}" Binding="{Binding ProxyTraffic}" Width="120" />
                        <DataGridTextColumn Header="{DynamicResource Column.DirectTraffic}" Binding="{Binding DirectTraffic}" Width="120" />
                        <DataGridTextColumn Header="{DynamicResource Column.UnknownTraffic}" Binding="{Binding UnknownTraffic}" Width="130" />
                        <DataGridTextColumn Header="{DynamicResource Column.Connections}" Binding="{Binding ConnectionCount}" Width="110" />
                        <DataGridTextColumn Header="{DynamicResource Column.Proxy}" Binding="{Binding ProxyCount}" Width="90" />
                        <DataGridTextColumn Header="{DynamicResource Column.Direct}" Binding="{Binding DirectCount}" Width="90" />
                        <DataGridTextColumn Header="{DynamicResource Column.Block}" Binding="{Binding BlockCount}" Width="90" />
                        <DataGridTextColumn Header="{DynamicResource Column.Unknown}" Binding="{Binding UnknownCount}" Width="100" />
                        <DataGridTextColumn Header="{DynamicResource Column.LastSeen}" Binding="{Binding LastSeen}" Width="170" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="{DynamicResource Tab.LiveConnections}">
                <DataGrid ItemsSource="{Binding AttributedConnections}" Style="{StaticResource FlowLensDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource Column.Time}" Binding="{Binding Timestamp}" Width="170" />
                        <DataGridTextColumn Header="{DynamicResource Column.Application}" Binding="{Binding Application}" Width="170" />
                        <DataGridTextColumn Header="{DynamicResource Column.Pid}" Binding="{Binding ProcessId}" Width="80" />
                        <DataGridTextColumn Header="{DynamicResource Column.SourcePort}" Binding="{Binding SourcePort}" Width="110" />
                        <DataGridTextColumn Header="{DynamicResource Column.Target}" Binding="{Binding Target}" Width="2*" />
                        <DataGridTextColumn Header="{DynamicResource Column.Inbound}" Binding="{Binding Inbound}" Width="100" />
                        <DataGridTextColumn Header="{DynamicResource Column.Outbound}" Binding="{Binding Outbound}" Width="100" />
                        <DataGridTextColumn Header="{DynamicResource Column.Mode}" Binding="{Binding AttributionModeDisplay}" Width="110" />
                        <DataGridTextColumn Header="{DynamicResource Column.Confidence}" Binding="{Binding ConfidenceDisplay}" Width="110" />
                        <DataGridTextColumn Header="{DynamicResource Column.Sent}" Binding="{Binding SentTraffic}" Width="100" />
                        <DataGridTextColumn Header="{DynamicResource Column.Received}" Binding="{Binding ReceivedTraffic}" Width="100" />
                        <DataGridTextColumn Header="{DynamicResource Column.Total}" Binding="{Binding TotalTraffic}" Width="100" />
                        <DataGridTextColumn Header="{DynamicResource Column.Status}" Binding="{Binding Status}" Width="100" />
                        <DataGridTextColumn Header="{DynamicResource Column.Evidence}" Binding="{Binding Evidence}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="{DynamicResource Tab.Session}">
                <Grid Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
                        <Button x:Name="ExportSessionApplicationsButton" Content="{DynamicResource Action.ExportApplicationsCsv}" MinHeight="30" MinWidth="170" Margin="0,0,10,0" Click="ExportSessionApplicationsButton_Click" />
                        <Button x:Name="ExportSessionDomainsButton" Content="{DynamicResource Action.ExportDomainsCsv}" MinHeight="30" MinWidth="150" Click="ExportSessionDomainsButton_Click" />
                    </StackPanel>
                    <GroupBox Grid.Row="1" Header="{DynamicResource Group.Applications}" Margin="8,0,8,8">
                        <DataGrid ItemsSource="{Binding SessionApplicationSummaries}" Style="{StaticResource FlowLensDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Column.Application}" Binding="{Binding Application}" Width="2*" />
                                <DataGridTextColumn Header="{DynamicResource Column.Pid}" Binding="{Binding ProcessId}" Width="90" />
                                <DataGridTextColumn Header="{DynamicResource Column.TotalTraffic}" Binding="{Binding TotalTraffic}" Width="120" />
                                <DataGridTextColumn Header="{DynamicResource Column.ProxyTraffic}" Binding="{Binding ProxyTraffic}" Width="120" />
                                <DataGridTextColumn Header="{DynamicResource Column.DirectTraffic}" Binding="{Binding DirectTraffic}" Width="120" />
                                <DataGridTextColumn Header="{DynamicResource Column.UnknownTraffic}" Binding="{Binding UnknownTraffic}" Width="130" />
                                <DataGridTextColumn Header="{DynamicResource Column.Connections}" Binding="{Binding ConnectionCount}" Width="110" />
                                <DataGridTextColumn Header="{DynamicResource Column.Proxy}" Binding="{Binding ProxyCount}" Width="90" />
                                <DataGridTextColumn Header="{DynamicResource Column.Direct}" Binding="{Binding DirectCount}" Width="90" />
                                <DataGridTextColumn Header="{DynamicResource Column.Unknown}" Binding="{Binding UnknownCount}" Width="100" />
                                <DataGridTextColumn Header="{DynamicResource Column.LastSeen}" Binding="{Binding LastSeen}" Width="170" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                    <GroupBox Grid.Row="2" Header="{DynamicResource Group.Domains}" Margin="8,0,8,8">
                        <DataGrid ItemsSource="{Binding SessionDomainSummaries}" Style="{StaticResource FlowLensDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Column.Domain}" Binding="{Binding Domain}" Width="2*" />
                                <DataGridTextColumn Header="{DynamicResource Column.Traffic}" Binding="{Binding TotalTraffic}" Width="120" />
                                <DataGridTextColumn Header="{DynamicResource Column.Connections}" Binding="{Binding ConnectionCount}" Width="120" />
                                <DataGridTextColumn Header="{DynamicResource Column.Applications}" Binding="{Binding Applications}" Width="2*" />
                                <DataGridTextColumn Header="{DynamicResource Column.Proxy}" Binding="{Binding ProxyCount}" Width="90" />
                                <DataGridTextColumn Header="{DynamicResource Column.Direct}" Binding="{Binding DirectCount}" Width="90" />
                                <DataGridTextColumn Header="{DynamicResource Column.Unknown}" Binding="{Binding UnknownCount}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>
            <TabItem Header="{DynamicResource Tab.Today}">
                <Grid Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
                        <Button x:Name="ExportTodayApplicationsButton" Content="{DynamicResource Action.ExportApplicationsCsv}" MinHeight="30" MinWidth="200" Margin="0,0,10,0" Click="ExportTodayApplicationsButton_Click" />
                        <Button x:Name="ExportTodayDomainsButton" Content="{DynamicResource Action.ExportDomainsCsv}" MinHeight="30" MinWidth="180" Click="ExportTodayDomainsButton_Click" />
                    </StackPanel>
                    <GroupBox Grid.Row="1" Header="{DynamicResource Group.TodayApplications}" Margin="8,0,8,8">
                        <DataGrid ItemsSource="{Binding TodayApplicationSummaries}" Style="{StaticResource FlowLensDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Column.Application}" Binding="{Binding Application}" Width="2*" />
                                <DataGridTextColumn Header="{DynamicResource Column.Pid}" Binding="{Binding ProcessId}" Width="90" />
                                <DataGridTextColumn Header="{DynamicResource Column.TotalTraffic}" Binding="{Binding TotalTraffic}" Width="120" />
                                <DataGridTextColumn Header="{DynamicResource Column.ProxyTraffic}" Binding="{Binding ProxyTraffic}" Width="120" />
                                <DataGridTextColumn Header="{DynamicResource Column.DirectTraffic}" Binding="{Binding DirectTraffic}" Width="120" />
                                <DataGridTextColumn Header="{DynamicResource Column.UnknownTraffic}" Binding="{Binding UnknownTraffic}" Width="130" />
                                <DataGridTextColumn Header="{DynamicResource Column.Connections}" Binding="{Binding ConnectionCount}" Width="110" />
                                <DataGridTextColumn Header="{DynamicResource Column.LastSeen}" Binding="{Binding LastSeen}" Width="170" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                    <GroupBox Grid.Row="2" Header="{DynamicResource Group.TodayDomains}" Margin="8,0,8,8">
                        <DataGrid ItemsSource="{Binding TodayDomainSummaries}" Style="{StaticResource FlowLensDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Column.Domain}" Binding="{Binding Domain}" Width="2*" />
                                <DataGridTextColumn Header="{DynamicResource Column.TotalTraffic}" Binding="{Binding TotalTraffic}" Width="120" />
                                <DataGridTextColumn Header="{DynamicResource Column.ProxyTraffic}" Binding="{Binding ProxyTraffic}" Width="120" />
                                <DataGridTextColumn Header="{DynamicResource Column.DirectTraffic}" Binding="{Binding DirectTraffic}" Width="120" />
                                <DataGridTextColumn Header="{DynamicResource Column.UnknownTraffic}" Binding="{Binding UnknownTraffic}" Width="130" />
                                <DataGridTextColumn Header="{DynamicResource Column.Connections}" Binding="{Binding ConnectionCount}" Width="120" />
                                <DataGridTextColumn Header="{DynamicResource Column.Applications}" Binding="{Binding Applications}" Width="2*" />
                                <DataGridTextColumn Header="{DynamicResource Column.LastSeen}" Binding="{Binding LastSeen}" Width="170" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>
            <TabItem Header="{DynamicResource Tab.History}">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource Label.Date}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox x:Name="HistoryDateComboBox" ItemsSource="{Binding HistoryDates}" DisplayMemberPath="Display" MinWidth="150" MinHeight="30" Margin="0,0,10,0" SelectionChanged="HistoryDateComboBox_SelectionChanged" />
                        <Button x:Name="ExportHistoryApplicationsButton" Content="{DynamicResource Action.ExportSelectedDayApplicationsCsv}" MinHeight="30" MinWidth="240" Margin="0,0,10,0" Click="ExportHistoryApplicationsButton_Click" />
                        <Button x:Name="ExportHistoryDomainsButton" Content="{DynamicResource Action.ExportSelectedDayDomainsCsv}" MinHeight="30" MinWidth="220" Margin="0,0,10,0" Click="ExportHistoryDomainsButton_Click" />
                        <Button x:Name="HistoryOpenFolderButton" Content="{DynamicResource Action.OpenHistoryFolder}" MinHeight="30" MinWidth="150" Click="OpenHistoryFolderButton_Click" />
                    </StackPanel>
                    <GroupBox Grid.Row="1" Header="{DynamicResource Group.SelectedDayApplications}" Margin="0,0,0,8">
                        <DataGrid ItemsSource="{Binding HistoryApplicationSummaries}" Style="{StaticResource FlowLensDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Column.Application}" Binding="{Binding Application}" Width="2*" />
                                <DataGridTextColumn Header="{DynamicResource Column.Pid}" Binding="{Binding ProcessId}" Width="90" />
                                <DataGridTextColumn Header="{DynamicResource Column.TotalTraffic}" Binding="{Binding TotalTraffic}" Width="120" />
                                <DataGridTextColumn Header="{DynamicResource Column.ProxyTraffic}" Binding="{Binding ProxyTraffic}" Width="120" />
                                <DataGridTextColumn Header="{DynamicResource Column.DirectTraffic}" Binding="{Binding DirectTraffic}" Width="120" />
                                <DataGridTextColumn Header="{DynamicResource Column.UnknownTraffic}" Binding="{Binding UnknownTraffic}" Width="130" />
                                <DataGridTextColumn Header="{DynamicResource Column.Connections}" Binding="{Binding ConnectionCount}" Width="110" />
                                <DataGridTextColumn Header="{DynamicResource Column.LastSeen}" Binding="{Binding LastSeen}" Width="170" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                    <GroupBox Grid.Row="2" Header="{DynamicResource Group.SelectedDayDomains}">
                        <DataGrid ItemsSource="{Binding HistoryDomainSummaries}" Style="{StaticResource FlowLensDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Column.Domain}" Binding="{Binding Domain}" Width="2*" />
                                <DataGridTextColumn Header="{DynamicResource Column.TotalTraffic}" Binding="{Binding TotalTraffic}" Width="120" />
                                <DataGridTextColumn Header="{DynamicResource Column.ProxyTraffic}" Binding="{Binding ProxyTraffic}" Width="120" />
                                <DataGridTextColumn Header="{DynamicResource Column.DirectTraffic}" Binding="{Binding DirectTraffic}" Width="120" />
                                <DataGridTextColumn Header="{DynamicResource Column.UnknownTraffic}" Binding="{Binding UnknownTraffic}" Width="130" />
                                <DataGridTextColumn Header="{DynamicResource Column.Connections}" Binding="{Binding ConnectionCount}" Width="120" />
                                <DataGridTextColumn Header="{DynamicResource Column.Applications}" Binding="{Binding Applications}" Width="2*" />
                                <DataGridTextColumn Header="{DynamicResource Column.LastSeen}" Binding="{Binding LastSeen}" Width="170" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>
            <TabItem Header="{DynamicResource Tab.Domains}">
                <DataGrid ItemsSource="{Binding DomainSummaries}" Style="{StaticResource FlowLensDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource Column.Domain}" Binding="{Binding Domain}" Width="2*" />
                        <DataGridTextColumn Header="{DynamicResource Column.Traffic}" Binding="{Binding TotalTraffic}" Width="120" />
                        <DataGridTextColumn Header="{DynamicResource Column.Connections}" Binding="{Binding ConnectionCount}" Width="120" />
                        <DataGridTextColumn Header="{DynamicResource Column.Applications}" Binding="{Binding Applications}" Width="2*" />
                        <DataGridTextColumn Header="{DynamicResource Column.Proxy}" Binding="{Binding ProxyCount}" Width="90" />
                        <DataGridTextColumn Header="{DynamicResource Column.Direct}" Binding="{Binding DirectCount}" Width="90" />
                        <DataGridTextColumn Header="{DynamicResource Column.Unknown}" Binding="{Binding UnknownCount}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="{DynamicResource Tab.Diagnostics}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Label.Admin}" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentDiagnostics.AdminDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource Label.Etw}" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentDiagnostics.EtwStatus}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Label.AccessLog}" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentDiagnostics.LogDiscoveryStatus}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource Label.LogHealth}" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CurrentDiagnostics.LogHealthStatus}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource Label.V2rayNConfig}" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CurrentDiagnostics.V2rayNConfigStatus}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource Label.V2rayNRoot}" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding CurrentDiagnostics.V2rayNRootDirectory}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource Label.ConfigMessage}" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding CurrentDiagnostics.V2rayNConfigMessage}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="{DynamicResource Label.ProxyPorts}" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding CurrentDiagnostics.ProxyPortsDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="{DynamicResource Label.ActiveLogs}" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding CurrentDiagnostics.ActiveLogsDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="9" Grid.Column="0" Text="{DynamicResource Label.MatchStats}" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding CurrentDiagnostics.MatchStatsDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="10" Grid.Column="0" Text="{DynamicResource Label.LastRefresh}" FontWeight="SemiBold" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding CurrentDiagnostics.LastRefreshDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="11" Grid.Column="0" Text="{DynamicResource Label.RefreshState}" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding RefreshStateDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="12" Grid.Column="0" Text="{DynamicResource Label.TrayMode}" FontWeight="SemiBold" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding TrayModeDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="13" Grid.Column="0" Text="{DynamicResource Label.SessionStarted}" FontWeight="SemiBold" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="13" Grid.Column="1" Text="{Binding SessionStartedDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="14" Grid.Column="0" Text="{DynamicResource Label.TodayHistory}" FontWeight="SemiBold" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="14" Grid.Column="1" Text="{Binding CurrentDiagnostics.TodayHistoryDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="15" Grid.Column="0" Text="{DynamicResource Label.AttributionMode}" FontWeight="SemiBold" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="15" Grid.Column="1" Text="{Binding CurrentDiagnostics.AttributionModeDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="16" Grid.Column="0" Text="{DynamicResource Label.TunEvidence}" FontWeight="SemiBold" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="16" Grid.Column="1" Text="{Binding CurrentDiagnostics.TunEvidenceDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="17" Grid.Column="0" Text="{DynamicResource Label.Confidence}" FontWeight="SemiBold" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="17" Grid.Column="1" Text="{Binding CurrentDiagnostics.ConfidenceStatsDisplay}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="18" Grid.Column="0" Text="{DynamicResource Action.CopyTunEvidence}" FontWeight="SemiBold" Margin="0,10,12,0" />
                        <Button Grid.Row="18" Grid.Column="1" Content="{DynamicResource Action.CopyTunEvidence}" Width="190" HorizontalAlignment="Left" Margin="0,10,0,0" Click="CopyTunEvidenceJsonButton_Click" />
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="4" Background="{StaticResource FlowLensPanelBrush}" BorderBrush="{StaticResource FlowLensBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10,7" Margin="0,10,0,0">
            <TextBlock x:Name="StatusTextBlock" Text="{DynamicResource Status.Ready}" Foreground="{StaticResource FlowLensMutedBrush}" TextTrimming="CharacterEllipsis" />
        </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
