<Window x:Class="V2rayN.FlowLens.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="v2rayN FlowLens" Height="760" Width="1180" MinHeight="640" MinWidth="960"
        Background="{StaticResource FlowLensSurfaceBrush}"
        Foreground="{StaticResource FlowLensTextBrush}"
        FontFamily="Segoe UI">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource FlowLensPanelBorderStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.1*" MinWidth="260" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                    <TextBlock Text="Log file or directory" Style="{StaticResource FlowLensLabelStyle}" />
                    <TextBox x:Name="LogPathTextBox" Style="{StaticResource FlowLensInputStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,10">
                    <TextBlock Text="Proxy ports" Style="{StaticResource FlowLensLabelStyle}" />
                    <TextBox x:Name="ProxyPortsTextBox" Text="10808,10809" Style="{StaticResource FlowLensInputStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,10,10">
                    <TextBlock Text="Refresh" Style="{StaticResource FlowLensLabelStyle}" />
                    <TextBox x:Name="RefreshSecondsTextBox" Text="2" Style="{StaticResource FlowLensInputStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,10,10">
                    <TextBlock Text="Mode" Style="{StaticResource FlowLensLabelStyle}" />
                    <ComboBox x:Name="AttributionModeComboBox" Style="{StaticResource FlowLensInputStyle}" SelectedIndex="0">
                        <ComboBoxItem Content="NormalProxy" />
                        <ComboBoxItem Content="Tun" />
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,10">
                    <Button x:Name="RefreshButton" Content="Refresh" Style="{StaticResource FlowLensPrimaryButtonStyle}" Margin="0,0,8,0" Click="RefreshButton_Click" />
                    <Button x:Name="PauseButton" Content="Pause" Style="{StaticResource FlowLensSecondaryButtonStyle}" Margin="0,0,8,0" Click="PauseButton_Click" />
                    <Button x:Name="ResetSessionButton" Content="Reset Session" Style="{StaticResource FlowLensSecondaryButtonStyle}" Click="ResetSessionButton_Click" />
                </StackPanel>

                <WrapPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5" Margin="0,0,0,8">
                    <CheckBox x:Name="HideCoreProcessesCheckBox" Content="Hide cores" IsChecked="True" VerticalAlignment="Center" Margin="0,0,14,0" />
                    <CheckBox x:Name="OnlyProxyCheckBox" Content="Proxy only" VerticalAlignment="Center" Margin="0,0,18,0" />
                    <TextBlock Text="Filter" Style="{StaticResource FlowLensLabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox x:Name="FilterTextBox" Width="220" Style="{StaticResource FlowLensInputStyle}" Margin="0,0,10,0" TextChanged="FilterControl_Changed" />
                    <ComboBox x:Name="OutboundFilterComboBox" Width="130" Style="{StaticResource FlowLensInputStyle}" Margin="0,0,10,0" SelectionChanged="FilterControl_Changed" SelectedIndex="0">
                        <ComboBoxItem Content="All" />
                        <ComboBoxItem Content="proxy" />
                        <ComboBoxItem Content="direct" />
                        <ComboBoxItem Content="unknown" />
                    </ComboBox>
                    <Button x:Name="OpenHistoryFolderButton" Content="History Folder" Style="{StaticResource FlowLensSecondaryButtonStyle}" Margin="0,0,8,0" Click="OpenHistoryFolderButton_Click" />
                    <Button x:Name="CopyDiagnosticsButton" Content="Copy Diagnostics" Style="{StaticResource FlowLensSecondaryButtonStyle}" Margin="0,0,8,0" Click="CopyDiagnosticsButton_Click" />
                    <Button x:Name="CopyTunEvidenceTopButton" Content="Copy TUN Evidence JSON" Style="{StaticResource FlowLensSecondaryButtonStyle}" Click="CopyTunEvidenceJsonButton_Click" />
                </WrapPanel>

                <WrapPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5">
                    <Border Style="{StaticResource FlowLensChipStyle}" Background="{StaticResource FlowLensChipAccentBrush}">
                        <TextBlock Text="{Binding CurrentDiagnostics.AdminDisplay}" TextTrimming="CharacterEllipsis" />
                    </Border>
                    <Border Style="{StaticResource FlowLensChipStyle}">
                        <TextBlock Text="{Binding CurrentDiagnostics.EtwStatus}" TextTrimming="CharacterEllipsis" MaxWidth="260" />
                    </Border>
                    <Border Style="{StaticResource FlowLensChipStyle}">
                        <TextBlock Text="{Binding CurrentDiagnostics.AttributionModeDisplay}" TextTrimming="CharacterEllipsis" MaxWidth="180" />
                    </Border>
                    <Border Style="{StaticResource FlowLensChipStyle}">
                        <TextBlock Text="{Binding CurrentDiagnostics.LogDiscoveryStatus, StringFormat=Logs: {0}}" TextTrimming="CharacterEllipsis" MaxWidth="160" />
                    </Border>
                    <Border Style="{StaticResource FlowLensChipStyle}">
                        <TextBlock Text="{Binding CurrentDiagnostics.ConfidenceStatsDisplay}" TextTrimming="CharacterEllipsis" MaxWidth="330" />
                    </Border>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" x:Name="LogHealthWarningBorder" Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12" Visibility="Collapsed">
            <TextBlock x:Name="LogHealthWarningTextBlock"
                       Foreground="#92400E"
                       TextWrapping="Wrap"
                       Text="未检测到 v2rayN 核心路由日志。当前只能识别应用连接了本地代理端口，无法判断 proxy/direct。请在 v2rayN 设置里开启 Core 日志，并把日志级别设为 info，然后重启 v2rayN 核心。" />
        </Border>

        <Border Grid.Row="2" x:Name="EtwWarningBorder" Background="#EFF6FF" BorderBrush="#60A5FA" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12" Visibility="Collapsed">
            <TextBlock x:Name="EtwWarningTextBlock"
                       Foreground="#1D4ED8"
                       TextWrapping="Wrap" />
        </Border>

        <TabControl Grid.Row="3" Background="{StaticResource FlowLensPanelBrush}" BorderBrush="{StaticResource FlowLensBorderBrush}">
            <TabItem Header="Applications">
                <DataGrid ItemsSource="{Binding ApplicationSummaries}" Style="{StaticResource FlowLensDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Application" Binding="{Binding Application}" Width="2*" />
                        <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="90" />
                        <DataGridTextColumn Header="Total traffic" Binding="{Binding TotalTraffic}" Width="120" />
                        <DataGridTextColumn Header="Proxy traffic" Binding="{Binding ProxyTraffic}" Width="120" />
                        <DataGridTextColumn Header="Direct traffic" Binding="{Binding DirectTraffic}" Width="120" />
                        <DataGridTextColumn Header="Unknown traffic" Binding="{Binding UnknownTraffic}" Width="130" />
                        <DataGridTextColumn Header="Connections" Binding="{Binding ConnectionCount}" Width="110" />
                        <DataGridTextColumn Header="Proxy" Binding="{Binding ProxyCount}" Width="90" />
                        <DataGridTextColumn Header="Direct" Binding="{Binding DirectCount}" Width="90" />
                        <DataGridTextColumn Header="Block" Binding="{Binding BlockCount}" Width="90" />
                        <DataGridTextColumn Header="Unknown" Binding="{Binding UnknownCount}" Width="100" />
                        <DataGridTextColumn Header="Last seen" Binding="{Binding LastSeen}" Width="170" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Live Connections">
                <DataGrid ItemsSource="{Binding AttributedConnections}" Style="{StaticResource FlowLensDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="170" />
                        <DataGridTextColumn Header="Application" Binding="{Binding Application}" Width="170" />
                        <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="80" />
                        <DataGridTextColumn Header="Source port" Binding="{Binding SourcePort}" Width="110" />
                        <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="2*" />
                        <DataGridTextColumn Header="Inbound" Binding="{Binding Inbound}" Width="100" />
                        <DataGridTextColumn Header="Outbound" Binding="{Binding Outbound}" Width="100" />
                        <DataGridTextColumn Header="Mode" Binding="{Binding AttributionModeDisplay}" Width="110" />
                        <DataGridTextColumn Header="Confidence" Binding="{Binding ConfidenceDisplay}" Width="110" />
                        <DataGridTextColumn Header="Sent" Binding="{Binding SentTraffic}" Width="100" />
                        <DataGridTextColumn Header="Received" Binding="{Binding ReceivedTraffic}" Width="100" />
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalTraffic}" Width="100" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                        <DataGridTextColumn Header="Evidence" Binding="{Binding Evidence}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Session">
                <Grid Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
                        <Button x:Name="ExportSessionApplicationsButton" Content="Export Applications CSV" MinHeight="30" MinWidth="170" Margin="0,0,10,0" Click="ExportSessionApplicationsButton_Click" />
                        <Button x:Name="ExportSessionDomainsButton" Content="Export Domains CSV" MinHeight="30" MinWidth="150" Click="ExportSessionDomainsButton_Click" />
                    </StackPanel>
                    <GroupBox Grid.Row="1" Header="Applications" Margin="8,0,8,8">
                        <DataGrid ItemsSource="{Binding SessionApplicationSummaries}" Style="{StaticResource FlowLensDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Application" Binding="{Binding Application}" Width="2*" />
                                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="90" />
                                <DataGridTextColumn Header="Total traffic" Binding="{Binding TotalTraffic}" Width="120" />
                                <DataGridTextColumn Header="Proxy traffic" Binding="{Binding ProxyTraffic}" Width="120" />
                                <DataGridTextColumn Header="Direct traffic" Binding="{Binding DirectTraffic}" Width="120" />
                                <DataGridTextColumn Header="Unknown traffic" Binding="{Binding UnknownTraffic}" Width="130" />
                                <DataGridTextColumn Header="Connections" Binding="{Binding ConnectionCount}" Width="110" />
                                <DataGridTextColumn Header="Proxy" Binding="{Binding ProxyCount}" Width="90" />
                                <DataGridTextColumn Header="Direct" Binding="{Binding DirectCount}" Width="90" />
                                <DataGridTextColumn Header="Unknown" Binding="{Binding UnknownCount}" Width="100" />
                                <DataGridTextColumn Header="Last seen" Binding="{Binding LastSeen}" Width="170" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                    <GroupBox Grid.Row="2" Header="Domains" Margin="8,0,8,8">
                        <DataGrid ItemsSource="{Binding SessionDomainSummaries}" Style="{StaticResource FlowLensDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Domain" Binding="{Binding Domain}" Width="2*" />
                                <DataGridTextColumn Header="Traffic" Binding="{Binding TotalTraffic}" Width="120" />
                                <DataGridTextColumn Header="Connections" Binding="{Binding ConnectionCount}" Width="120" />
                                <DataGridTextColumn Header="Applications" Binding="{Binding Applications}" Width="2*" />
                                <DataGridTextColumn Header="Proxy" Binding="{Binding ProxyCount}" Width="90" />
                                <DataGridTextColumn Header="Direct" Binding="{Binding DirectCount}" Width="90" />
                                <DataGridTextColumn Header="Unknown" Binding="{Binding UnknownCount}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>
            <TabItem Header="Today">
                <Grid Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
                        <Button x:Name="ExportTodayApplicationsButton" Content="Export Today Applications CSV" MinHeight="30" MinWidth="200" Margin="0,0,10,0" Click="ExportTodayApplicationsButton_Click" />
                        <Button x:Name="ExportTodayDomainsButton" Content="Export Today Domains CSV" MinHeight="30" MinWidth="180" Click="ExportTodayDomainsButton_Click" />
                    </StackPanel>
                    <GroupBox Grid.Row="1" Header="Today Applications" Margin="8,0,8,8">
                        <DataGrid ItemsSource="{Binding TodayApplicationSummaries}" Style="{StaticResource FlowLensDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Application" Binding="{Binding Application}" Width="2*" />
                                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="90" />
                                <DataGridTextColumn Header="Total traffic" Binding="{Binding TotalTraffic}" Width="120" />
                                <DataGridTextColumn Header="Proxy traffic" Binding="{Binding ProxyTraffic}" Width="120" />
                                <DataGridTextColumn Header="Direct traffic" Binding="{Binding DirectTraffic}" Width="120" />
                                <DataGridTextColumn Header="Unknown traffic" Binding="{Binding UnknownTraffic}" Width="130" />
                                <DataGridTextColumn Header="Connections" Binding="{Binding ConnectionCount}" Width="110" />
                                <DataGridTextColumn Header="Last seen" Binding="{Binding LastSeen}" Width="170" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                    <GroupBox Grid.Row="2" Header="Today Domains" Margin="8,0,8,8">
                        <DataGrid ItemsSource="{Binding TodayDomainSummaries}" Style="{StaticResource FlowLensDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Domain" Binding="{Binding Domain}" Width="2*" />
                                <DataGridTextColumn Header="Total traffic" Binding="{Binding TotalTraffic}" Width="120" />
                                <DataGridTextColumn Header="Proxy traffic" Binding="{Binding ProxyTraffic}" Width="120" />
                                <DataGridTextColumn Header="Direct traffic" Binding="{Binding DirectTraffic}" Width="120" />
                                <DataGridTextColumn Header="Unknown traffic" Binding="{Binding UnknownTraffic}" Width="130" />
                                <DataGridTextColumn Header="Connections" Binding="{Binding ConnectionCount}" Width="120" />
                                <DataGridTextColumn Header="Applications" Binding="{Binding Applications}" Width="2*" />
                                <DataGridTextColumn Header="Last seen" Binding="{Binding LastSeen}" Width="170" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>
            <TabItem Header="History">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Date" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox x:Name="HistoryDateComboBox" ItemsSource="{Binding HistoryDates}" DisplayMemberPath="Display" MinWidth="150" MinHeight="30" Margin="0,0,10,0" SelectionChanged="HistoryDateComboBox_SelectionChanged" />
                        <Button x:Name="ExportHistoryApplicationsButton" Content="Export Selected Day Applications CSV" MinHeight="30" MinWidth="240" Margin="0,0,10,0" Click="ExportHistoryApplicationsButton_Click" />
                        <Button x:Name="ExportHistoryDomainsButton" Content="Export Selected Day Domains CSV" MinHeight="30" MinWidth="220" Margin="0,0,10,0" Click="ExportHistoryDomainsButton_Click" />
                        <Button x:Name="HistoryOpenFolderButton" Content="Open History Folder" MinHeight="30" MinWidth="150" Click="OpenHistoryFolderButton_Click" />
                    </StackPanel>
                    <GroupBox Grid.Row="1" Header="Selected Day Applications" Margin="0,0,0,8">
                        <DataGrid ItemsSource="{Binding HistoryApplicationSummaries}" Style="{StaticResource FlowLensDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Application" Binding="{Binding Application}" Width="2*" />
                                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="90" />
                                <DataGridTextColumn Header="Total traffic" Binding="{Binding TotalTraffic}" Width="120" />
                                <DataGridTextColumn Header="Proxy traffic" Binding="{Binding ProxyTraffic}" Width="120" />
                                <DataGridTextColumn Header="Direct traffic" Binding="{Binding DirectTraffic}" Width="120" />
                                <DataGridTextColumn Header="Unknown traffic" Binding="{Binding UnknownTraffic}" Width="130" />
                                <DataGridTextColumn Header="Connections" Binding="{Binding ConnectionCount}" Width="110" />
                                <DataGridTextColumn Header="Last seen" Binding="{Binding LastSeen}" Width="170" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                    <GroupBox Grid.Row="2" Header="Selected Day Domains">
                        <DataGrid ItemsSource="{Binding HistoryDomainSummaries}" Style="{StaticResource FlowLensDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Domain" Binding="{Binding Domain}" Width="2*" />
                                <DataGridTextColumn Header="Total traffic" Binding="{Binding TotalTraffic}" Width="120" />
                                <DataGridTextColumn Header="Proxy traffic" Binding="{Binding ProxyTraffic}" Width="120" />
                                <DataGridTextColumn Header="Direct traffic" Binding="{Binding DirectTraffic}" Width="120" />
                                <DataGridTextColumn Header="Unknown traffic" Binding="{Binding UnknownTraffic}" Width="130" />
                                <DataGridTextColumn Header="Connections" Binding="{Binding ConnectionCount}" Width="120" />
                                <DataGridTextColumn Header="Applications" Binding="{Binding Applications}" Width="2*" />
                                <DataGridTextColumn Header="Last seen" Binding="{Binding LastSeen}" Width="170" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>
            <TabItem Header="Domains">
                <DataGrid ItemsSource="{Binding DomainSummaries}" Style="{StaticResource FlowLensDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Domain" Binding="{Binding Domain}" Width="2*" />
                        <DataGridTextColumn Header="Traffic" Binding="{Binding TotalTraffic}" Width="120" />
                        <DataGridTextColumn Header="Connections" Binding="{Binding ConnectionCount}" Width="120" />
                        <DataGridTextColumn Header="Applications" Binding="{Binding Applications}" Width="2*" />
                        <DataGridTextColumn Header="Proxy" Binding="{Binding ProxyCount}" Width="90" />
                        <DataGridTextColumn Header="Direct" Binding="{Binding DirectCount}" Width="90" />
                        <DataGridTextColumn Header="Unknown" Binding="{Binding UnknownCount}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Diagnostics">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Admin" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentDiagnostics.AdminDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="ETW" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentDiagnostics.EtwStatus}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Access log" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentDiagnostics.LogDiscoveryStatus}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Log health" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CurrentDiagnostics.LogHealthStatus}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="v2rayN config" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CurrentDiagnostics.V2rayNConfigStatus}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="v2rayN root" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding CurrentDiagnostics.V2rayNRootDirectory}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Config message" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding CurrentDiagnostics.V2rayNConfigMessage}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Proxy ports" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding CurrentDiagnostics.ProxyPortsDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Active logs" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding CurrentDiagnostics.ActiveLogsDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="9" Grid.Column="0" Text="Match stats" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding CurrentDiagnostics.MatchStatsDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="10" Grid.Column="0" Text="Last refresh" FontWeight="SemiBold" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding CurrentDiagnostics.LastRefreshDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="11" Grid.Column="0" Text="Refresh state" FontWeight="SemiBold" Margin="0,0,12,10" />
                        <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding RefreshStateDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="12" Grid.Column="0" Text="Tray mode" FontWeight="SemiBold" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding TrayModeDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="13" Grid.Column="0" Text="Session started" FontWeight="SemiBold" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="13" Grid.Column="1" Text="{Binding SessionStartedDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="14" Grid.Column="0" Text="Today history" FontWeight="SemiBold" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="14" Grid.Column="1" Text="{Binding CurrentDiagnostics.TodayHistoryDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="15" Grid.Column="0" Text="Attribution mode" FontWeight="SemiBold" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="15" Grid.Column="1" Text="{Binding CurrentDiagnostics.AttributionModeDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="16" Grid.Column="0" Text="TUN evidence" FontWeight="SemiBold" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="16" Grid.Column="1" Text="{Binding CurrentDiagnostics.TunEvidenceDisplay}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="17" Grid.Column="0" Text="Confidence" FontWeight="SemiBold" Margin="0,0,12,0" />
                        <TextBlock Grid.Row="17" Grid.Column="1" Text="{Binding CurrentDiagnostics.ConfidenceStatsDisplay}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="18" Grid.Column="0" Text="TUN evidence JSON" FontWeight="SemiBold" Margin="0,10,12,0" />
                        <Button Grid.Row="18" Grid.Column="1" Content="Copy TUN Evidence JSON" Width="190" HorizontalAlignment="Left" Margin="0,10,0,0" Click="CopyTunEvidenceJsonButton_Click" />
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="4" Background="{StaticResource FlowLensPanelBrush}" BorderBrush="{StaticResource FlowLensBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10,7" Margin="0,10,0,0">
            <TextBlock x:Name="StatusTextBlock" Text="Ready" Foreground="{StaticResource FlowLensMutedBrush}" TextTrimming="CharacterEllipsis" />
        </Border>
    </Grid>
</Window>
