<Window x:Class="V2rayN.FlowLens.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="v2rayN FlowLens" Height="760" Width="1180" MinHeight="640" MinWidth="960"
        Background="#F6F7F9">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#D8DEE8" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="100" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Log file or directory" FontWeight="SemiBold" Margin="0,0,10,4" />
                <TextBox Grid.Row="1" Grid.Column="0" x:Name="LogPathTextBox" Margin="0,0,10,0" MinHeight="30" VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="0" Grid.Column="1" Text="Proxy ports" FontWeight="SemiBold" Margin="0,0,10,4" />
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="ProxyPortsTextBox" Text="10808,10809" Margin="0,0,10,0" MinHeight="30" VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Refresh" FontWeight="SemiBold" Margin="0,0,10,4" />
                <TextBox Grid.Row="1" Grid.Column="2" x:Name="RefreshSecondsTextBox" Text="2" Margin="0,0,10,0" MinHeight="30" VerticalContentAlignment="Center" />

                <CheckBox Grid.Row="1" Grid.Column="3" x:Name="HideCoreProcessesCheckBox" Content="Hide cores" IsChecked="True" VerticalAlignment="Center" Margin="0,2,10,0" />
                <CheckBox Grid.Row="1" Grid.Column="4" x:Name="OnlyProxyCheckBox" Content="Proxy only" VerticalAlignment="Center" Margin="0,2,10,0" />
                <Button Grid.Row="1" Grid.Column="5" x:Name="RefreshButton" Content="Refresh" MinHeight="30" Click="RefreshButton_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="1" x:Name="LogHealthWarningBorder" Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12" Visibility="Collapsed">
            <TextBlock x:Name="LogHealthWarningTextBlock"
                       Foreground="#92400E"
                       TextWrapping="Wrap"
                       Text="未检测到 v2rayN 核心路由日志。当前只能识别应用连接了本地代理端口，无法判断 proxy/direct。请在 v2rayN 设置里开启 Core 日志，并把日志级别设为 info，然后重启 v2rayN 核心。" />
        </Border>

        <TabControl Grid.Row="2" Background="White" BorderBrush="#D8DEE8">
            <TabItem Header="Applications">
                <DataGrid ItemsSource="{Binding ApplicationSummaries}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Application" Binding="{Binding Application}" Width="2*" />
                        <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="90" />
                        <DataGridTextColumn Header="Total traffic" Binding="{Binding TotalTraffic}" Width="120" />
                        <DataGridTextColumn Header="Proxy traffic" Binding="{Binding ProxyTraffic}" Width="120" />
                        <DataGridTextColumn Header="Direct traffic" Binding="{Binding DirectTraffic}" Width="120" />
                        <DataGridTextColumn Header="Unknown traffic" Binding="{Binding UnknownTraffic}" Width="130" />
                        <DataGridTextColumn Header="Connections" Binding="{Binding ConnectionCount}" Width="110" />
                        <DataGridTextColumn Header="Proxy" Binding="{Binding ProxyCount}" Width="90" />
                        <DataGridTextColumn Header="Direct" Binding="{Binding DirectCount}" Width="90" />
                        <DataGridTextColumn Header="Block" Binding="{Binding BlockCount}" Width="90" />
                        <DataGridTextColumn Header="Unknown" Binding="{Binding UnknownCount}" Width="100" />
                        <DataGridTextColumn Header="Last seen" Binding="{Binding LastSeen}" Width="170" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Live Connections">
                <DataGrid ItemsSource="{Binding AttributedConnections}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="170" />
                        <DataGridTextColumn Header="Application" Binding="{Binding Application}" Width="170" />
                        <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="80" />
                        <DataGridTextColumn Header="Source port" Binding="{Binding SourcePort}" Width="110" />
                        <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="2*" />
                        <DataGridTextColumn Header="Inbound" Binding="{Binding Inbound}" Width="100" />
                        <DataGridTextColumn Header="Outbound" Binding="{Binding Outbound}" Width="100" />
                        <DataGridTextColumn Header="Sent" Binding="{Binding SentTraffic}" Width="100" />
                        <DataGridTextColumn Header="Received" Binding="{Binding ReceivedTraffic}" Width="100" />
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalTraffic}" Width="100" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Domains">
                <DataGrid ItemsSource="{Binding DomainSummaries}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Domain" Binding="{Binding Domain}" Width="2*" />
                        <DataGridTextColumn Header="Traffic" Binding="{Binding TotalTraffic}" Width="120" />
                        <DataGridTextColumn Header="Connections" Binding="{Binding ConnectionCount}" Width="120" />
                        <DataGridTextColumn Header="Applications" Binding="{Binding Applications}" Width="2*" />
                        <DataGridTextColumn Header="Proxy" Binding="{Binding ProxyCount}" Width="90" />
                        <DataGridTextColumn Header="Direct" Binding="{Binding DirectCount}" Width="90" />
                        <DataGridTextColumn Header="Unknown" Binding="{Binding UnknownCount}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="3" x:Name="StatusTextBlock" Text="Ready" Margin="2,10,0,0" Foreground="#4B5563" />
    </Grid>
</Window>
